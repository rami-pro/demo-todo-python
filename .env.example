# Copy this file to .env and fill in your values.
# django-environ reads this file automatically via environ.Env.read_env().

# Django core
SECRET_KEY=django-insecure-replace-this-in-production-use-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# SQLite (default for local development — zero setup required):
DATABASE_URL=sqlite:///db.sqlite3
# PostgreSQL (Docker / production):
# DATABASE_URL=postgresql://todo_user:todo_password@localhost:5432/todo_db

# JWT token lifetimes
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7
